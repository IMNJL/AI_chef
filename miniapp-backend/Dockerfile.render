FROM maven:3.9.9-eclipse-temurin-21 AS build
WORKDIR /app

COPY pom.xml ./pom.xml
COPY backend-core ./backend-core
COPY telegram-backend ./telegram-backend
COPY miniapp-backend ./miniapp-backend
COPY frontend ./frontend

RUN mvn -pl miniapp-backend -am -DskipTests package

FROM eclipse-temurin:21-jre
WORKDIR /app

COPY --from=build /app/miniapp-backend/target/miniapp-backend-*.jar /app/app.jar

CMD ["sh", "-c", "java -jar /app/app.jar --server.port=${PORT:-10000}"]
