FROM maven:3.9.9-eclipse-temurin-21 AS build
WORKDIR /app

COPY pom.xml ./pom.xml
COPY backend-core ./backend-core
COPY miniapp-backend ./miniapp-backend
COPY telegram-backend ./telegram-backend
COPY frontend ./frontend

RUN mvn -pl telegram-backend -am -DskipTests package

FROM eclipse-temurin:21-jre
WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ffmpeg python3 python3-pip python3-venv \
    && python3 -m venv /opt/venv \
    && /opt/venv/bin/pip install --no-cache-dir --upgrade pip setuptools wheel \
    && /opt/venv/bin/pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cpu torch \
    && /opt/venv/bin/pip install --no-cache-dir openai-whisper --no-deps \
    && /opt/venv/bin/pip install --no-cache-dir numpy numba tiktoken tqdm more-itertools regex requests \
    && rm -rf /var/lib/apt/lists/*

ENV PATH="/opt/venv/bin:${PATH}"

COPY --from=build /app/telegram-backend/target/telegram-backend-*.jar /app/app.jar

CMD ["sh", "-c", "java -jar /app/app.jar --server.port=${PORT:-10000}"]
